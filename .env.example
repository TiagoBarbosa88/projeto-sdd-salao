# Banco de dados (dev local + producao)
POSTGRES_DB=salao
POSTGRES_USER=salao
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5432

# Backend — desenvolvimento local
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/salao
SPRING_DATASOURCE_USERNAME=salao
SPRING_DATASOURCE_PASSWORD=salao_dev
SERVER_PORT=8080

# Backend — producao (obrigatorio alterar)
JWT_SECRET=change-me-in-production-use-at-least-32-characters
JWT_EXPIRATION_MS=86400000
SALAO_WHATSAPP_ENABLED=true
SALAO_WHATSAPP_PROVIDER=mock

# Frontend — desenvolvimento local
FRONTEND_PORT=4200

# Producao (docker-compose.prod.yml)
WEB_PORT=80
